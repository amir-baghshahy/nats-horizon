# NATS Monitoring - Environment Variables

# Server Configuration
SERVER_PORT=3000
GIN_MODE=debug  # debug, release, or test

# NATS Connection
NATS_URL=nats://localhost:4222

# CORS Configuration
CORS_ALLOWED_ORIGINS=*  # Comma-separated list of origins, e.g., "http://localhost:5173,http://localhost:3000"

# Pagination
DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=100

# WebSocket Configuration
WS_ENABLE_PING=true
WS_PING_INTERVAL=30  # seconds
